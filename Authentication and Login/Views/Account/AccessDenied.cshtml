@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - BlindMatch</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1f2e 0%, #16213e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
            color: #e0e0e0;
        }

        .error-container {
            text-align: center;
            max-width: 400px;
            padding: 0 20px;
        }

        .error-card {
            background: rgba(30, 30, 40, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 50px 40px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .error-icon {
            font-size: 64px;
            margin-bottom: 20px;
            color: #ff6b6b;
        }

        .error-title {
            font-family: 'Syne', sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 12px;
        }

        .error-text {
            color: #b0b0b0;
            font-size: 14px;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .error-link {
            display: inline-block;
            background: linear-gradient(135deg, #64c8ff 0%, #4ca8dd 100%);
            border: none;
            color: #ffffff;
            font-weight: 600;
            padding: 10px 24px;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .error-link:hover {
            background: linear-gradient(135deg, #7dd9ff 0%, #5fb8ed 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(100, 200, 255, 0.3);
            color: #ffffff;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-card">
            <div class="error-icon">🔒</div>
            <h1 class="error-title">Access Denied</h1>
            <p class="error-text">
                You don't have permission to access this resource. 
                Please return to your dashboard or contact support if you believe this is an error.
            </p>
            <a href="javascript:history.back()" class="error-link">Go Back</a>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
