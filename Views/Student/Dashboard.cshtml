@model List<Project>
@{
    ViewData["Title"] = "My Projects";
}

<div class="row mb-4">
    <div class="col">
        <h1>My Projects</h1>
        <p class="text-muted">Manage and track your project submissions</p>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-primary">+ Submit New Project</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-3">You haven't submitted any projects yet.</p>
            <a asp-action="Create" class="btn btn-primary">Submit Your First Project</a>
        </div>
    </div>
}
else
{
    <div class="row gap-3">
        @foreach (var project in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="card-title mb-0">@project.Title.Substring(0, Math.Min(30, project.Title.Length))@(project.Title.Length > 30 ? "..." : "")</span>
                    </div>
                    <div class="card-body">
                        <p class="card-text small">@project.Abstract.Substring(0, Math.Min(100, project.Abstract.Length))...</p>
                        
                        <div class="mb-3">
                            <small class="text-muted">Research Area</small>
                            <p class="mb-2">@project.ResearchArea?.Name</p>
                        </div>

                        <div class="d-flex gap-2 mb-3 flex-wrap">
                            @switch (project.Status)
                            {
                                case ProjectStatus.Pending:
                                    <span class="badge bg-info text-dark">Pending</span>
                                    break;
                                case ProjectStatus.UnderReview:
                                    <span class="badge bg-warning text-dark">Under Review</span>
                                    break;
                                case ProjectStatus.Matched:
                                    <span class="badge bg-success">Matched</span>
                                    break;
                                case ProjectStatus.Withdrawn:
                                    <span class="badge bg-danger">Withdrawn</span>
                                    break;
                            }
                            <span class="badge bg-secondary">@project.SubmittedAt.ToString("MMM d, yyyy")</span>
                        </div>

                        <div class="d-grid gap-2">
                            @if (project.Status == ProjectStatus.Matched)
                            {
                                <a asp-controller="Match" asp-action="Reveal" asp-route-projectId="@project.Id" class="btn btn-sm btn-success">
                                    <i class="bi bi-eye me-1"></i>View Match
                                </a>
                            }
                            else if (project.Status != ProjectStatus.Withdrawn)
                            {
                                <a asp-controller="Match" asp-action="Status" asp-route-projectId="@project.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-clock-history me-1"></i>View Status
                                </a>
                                <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                            }
                        </div>
                    </div>
                    <div class="card-footer border-top">
                        @if (project.Status == ProjectStatus.Pending || project.Status == ProjectStatus.UnderReview)
                        {
                            <form method="post" asp-action="Withdraw" asp-route-id="@project.Id" style="display: inline; width: 100%;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Are you sure you want to withdraw this project?')">
                                    Withdraw
                                </button>
                            </form>
                        }
                        else if (project.Status == ProjectStatus.Withdrawn)
                        {
                            <span class="text-muted small">Withdrawn</span>
                        }
                        else
                        {
                            <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Matched</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
