<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS Admin</title>
    <link rel="stylesheet" href="~/css/nothing.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- SIDEBAR NAVIGATION -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <h2>Blind-Match</h2>
                <span>PAS // ADMIN.v1</span>
            </div>
            <nav class="sidebar-nav">
                <a href="@Url.Action("Dashboard", "Admin")" class="@(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                    <span class="nav-icon">◉</span>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Index", "ResearchArea")" class="@(ViewData["ActivePage"]?.ToString() == "ResearchArea" ? "active" : "")">
                    <span class="nav-icon">◈</span>
                    <span>Research Areas</span>
                </a>
                <a href="@Url.Action("Index", "Supervisor")" class="@(ViewData["ActivePage"]?.ToString() == "Supervisor" ? "active" : "")">
                    <span class="nav-icon">👤</span>
                    <span>Supervisors</span>
                </a>
                <a href="@Url.Action("AllocationOverview", "Admin")" class="@(ViewData["ActivePage"]?.ToString() == "Allocation" ? "active" : "")">
                    <span class="nav-icon">◇</span>
                    <span>Allocation</span>
                </a>
                <a href="@Url.Action("UserManagement", "Admin")" class="@(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")">
                    <span class="nav-icon">○</span>
                    <span>Workload</span>
                </a>
                <a href="@Url.Action("Analysis", "Admin")" class="@(ViewData["ActivePage"]?.ToString() == "Analysis" ? "active" : "")">
                    <span class="nav-icon">△</span>
                    <span>Analysis</span>
                </a>
                <a href="@Url.Action("AdminUsers", "Admin")" class="@(ViewData["ActivePage"]?.ToString() == "AdminUsers" ? "active" : "")">
                    <span class="nav-icon">⚙</span>
                    <span>Admin Settings</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <form method="post" asp-action="Logout" asp-controller="Admin">
                    <button type="submit" class="logout-btn">↳ LOGOUT</button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            @RenderBody()
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
