<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS Admin</title>
    <link rel="stylesheet" href="~/css/nothing.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-container">
        <header class="login-header">
            <h1 class="login-title">Blind-Match PAS</h1>
            <div class="login-subtitle">ADMIN.PORTAL // SECURE_ACCESS</div>
        </header>

        <main>
            @RenderBody()
        </main>

        <footer class="login-footer">
            <span>&copy; 2026 PAS.SYSTEM</span>
            <span>ENCRYPTED.LINK</span>
        </footer>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
