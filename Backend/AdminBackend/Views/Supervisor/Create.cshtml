@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "New Supervisor";
    ViewData["ActivePage"] = "Supervisor";
}

<div class="page-header">
    <h1 class="page-title">Register Supervisor</h1>
    <p class="page-subtitle">NEW // STAFF ENTRY</p>
</div>

<div class="form-card">
    <form method="post" asp-action="Create" asp-controller="Supervisor">
        <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="e.g. Dr. John Watson" required />
        </div>

        <div class="form-group">
            <label for="department">Department</label>
            <input type="text" id="department" name="department" placeholder="e.g. Computer Science" required />
        </div>

        <div class="btn-group">
            <button type="submit" class="nothing-button">Add Supervisor</button>
            <a href="@Url.Action("Index", "Supervisor")" class="nothing-button btn-outline">Cancel</a>
        </div>
    </form>
</div>
