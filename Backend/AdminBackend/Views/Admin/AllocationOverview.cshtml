@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Allocation";
    ViewData["ActivePage"] = "Allocation";

    var projects = (List<AdminBackend.Models.Project>)ViewBag.Projects;
    var supervisors = (List<AdminBackend.Models.Supervisor>)ViewBag.Supervisors;
    var areas = (List<AdminBackend.Models.ResearchArea>)ViewBag.ResearchAreas;
}

<div class="page-header">
    <h1 class="page-title">Allocation Overview</h1>
    <p class="page-subtitle">PROJECT // SUPERVISOR MAPPING</p>
</div>

<div class="data-table-wrapper">
    <div class="table-header">
        <span class="table-title">All Projects</span>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Student</th>
                <th>Research Area</th>
                <th>Supervisor</th>
                <th>Status</th>
                <th>Reassign</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in projects)
            {
                var area = areas.FirstOrDefault(a => a.Id == project.ResearchAreaId);
                var supervisor = supervisors.FirstOrDefault(s => s.Id == project.SupervisorId);
                <tr>
                    <td>@project.Id</td>
                    <td>@project.Title</td>
                    <td>@(project.Student?.FullName ?? "N/A")</td>
                    <td>@(area?.Name ?? "N/A")</td>
                    <td>@(supervisor?.Name ?? "Unassigned")</td>
                    <td>
                        <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start;">
                            @if (project.IsRevealed)
                            {
                                <span class="badge badge-revealed">Revealed</span>
                            }
                            else
                            {
                                <span class="badge badge-hidden">Hidden</span>
                            }
                            <form method="post" asp-action="ToggleReveal" asp-controller="Admin" style="margin: 0;">
                                <input type="hidden" name="id" value="@project.Id" />
                                <button type="submit" class="nothing-button btn-sm btn-outline">Toggle</button>
                            </form>
                        </div>
                    </td>
                    <td>
                        <form method="post" asp-action="UpdateAllocation" asp-controller="Admin" style="display:flex; gap:0.5rem; align-items:center;">
                            <input type="hidden" name="projectId" value="@project.Id" />
                            <select name="supervisorId" style="padding:0.3rem; font-size:0.75rem; max-width: 140px;">
                                @foreach (var sup in supervisors)
                                {
                                    <option value="@sup.Id" selected="@(sup.Id == project.SupervisorId)">@sup.Name</option>
                                }
                            </select>
                            <button type="submit" class="nothing-button btn-sm">Apply</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>