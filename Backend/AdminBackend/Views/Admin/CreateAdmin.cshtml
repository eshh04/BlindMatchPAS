@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Register Admin";
    ViewData["ActivePage"] = "AdminUsers";
}

<div class="page-header">
    <h1 class="page-title">Register Administrator</h1>
    <p class="page-subtitle">NEW // ELEVATED ACCESS</p>
</div>

<div class="form-card">
    <form method="post" asp-action="CreateAdmin" asp-controller="Admin">
        <div class="form-group">
            <label for="email">Identification (Email)</label>
            <input type="email" id="email" name="email" placeholder="example@pas.com" required />
        </div>

        <div class="form-group">
            <label for="password">Security Code (Password)</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required />
        </div>

        <div class="btn-group">
            <button type="submit" class="nothing-button">Create Admin</button>
            <a href="@Url.Action("AdminUsers", "Admin")" class="nothing-button btn-outline">Cancel</a>
        </div>
    </form>
</div>
