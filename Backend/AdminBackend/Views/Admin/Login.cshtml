@{
    Layout = "_NothingLayout";
    ViewData["Title"] = "Login";
}

<form method="post" action="@Url.Action("Login", "Admin")">
    <div class="form-group">
        <label for="email">Identification</label>
        <input type="email" id="email" name="email" placeholder="ADMIN@PAS.COM" required autocomplete="email" />
    </div>

    <div class="form-group">
        <label for="password">Security Code</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password" />
    </div>

    <button type="submit" class="nothing-button">Authorize</button>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="error-message">
            @ViewBag.ErrorMessage
        </div>
    }
</form>
