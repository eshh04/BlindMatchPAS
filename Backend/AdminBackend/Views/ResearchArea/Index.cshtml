@model List<AdminBackend.Models.ResearchArea>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Research Areas";
    ViewData["ActivePage"] = "ResearchArea";
}

<div class="page-header" style="display:flex; justify-content:space-between; align-items:flex-end;">
    <div>
        <h1 class="page-title">Research Areas</h1>
        <p class="page-subtitle">CATEGORIES // DOMAIN MANAGEMENT</p>
    </div>
    <a href="@Url.Action("Create", "ResearchArea")" class="nothing-button btn-sm">+ New Area</a>
</div>

<div class="data-table-wrapper">
    <div class="table-header">
        <span class="table-title">All Research Areas (@Model.Count)</span>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Projects</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var area in Model)
            {
                var projectCount = AdminBackend.Services.MockDataService.Projects.Count(p => p.ResearchAreaId == area.Id);
                <tr>
                    <td>@area.Id</td>
                    <td>@area.Name</td>
                    <td style="color: var(--text-muted);">@area.Description</td>
                    <td><span style="color: var(--accent-blue); font-family: var(--font-heading);">@projectCount</span></td>
                    <td>
                        <div class="btn-group">
                            <a href="@Url.Action("Edit", "ResearchArea", new { id = area.Id })" class="nothing-button btn-sm btn-outline">Edit</a>
                            <form method="post" asp-action="Delete" asp-controller="ResearchArea" style="margin:0;">
                                <input type="hidden" name="id" value="@area.Id" />
                                <button type="submit" class="nothing-button btn-sm btn-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
