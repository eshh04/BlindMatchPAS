@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "New Research Area";
    ViewData["ActivePage"] = "ResearchArea";
}

<div class="page-header">
    <h1 class="page-title">Create Research Area</h1>
    <p class="page-subtitle">NEW // DOMAIN ENTRY</p>
</div>

<div class="form-card">
    <form method="post" asp-action="Create" asp-controller="ResearchArea">
        <div class="form-group">
            <label for="name">Area Name</label>
            <input type="text" id="name" name="name" placeholder="e.g. Quantum Computing" required />
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" placeholder="Brief description of this research domain..."></textarea>
        </div>

        <div class="btn-group">
            <button type="submit" class="nothing-button">Create Area</button>
            <a href="@Url.Action("Index", "ResearchArea")" class="nothing-button btn-outline">Cancel</a>
        </div>
    </form>
</div>
