<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
</head>
<body class="@(User.IsInRole("Admin") ? "admin-mode" : "user-mode")">
    
    @if (User.IsInRole("Admin"))
    {
        <div class="admin-layout">
            <aside class="sidebar py-4">
                <div class="px-4 mb-5">
                    <div class="d-flex align-items-center">
                        <span class="brand-dot"></span>
                        <span class="h5 mb-0 fw-bold gradient-text">BLINDMATCH PAS</span>
                    </div>
                </div>

                <nav class="flex-grow-1">
                    <a href="@Url.Action("Dashboard", "Admin")" class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-3"></i> OVERVIEW
                    </a>
                    <a href="@Url.Action("Index", "ResearchArea")" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ResearchArea" ? "active" : "")">
                        <i class="bi bi-diagram-3 me-3"></i> RESEARCH
                    </a>
                    <a href="@Url.Action("AllocationOverview", "Admin")" class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "AllocationOverview" ? "active" : "")">
                        <i class="bi bi-layers me-3"></i> ALLOCATION
                    </a>
                    <a href="@Url.Action("Projects", "Admin")" class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Projects" ? "active" : "")">
                        <i class="bi bi-folder2-open me-3"></i> PROJECTS
                    </a>
                    <a href="@Url.Action("UserManagement", "Admin")" class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "UserManagement" ? "active" : "")">
                        <i class="bi bi-people me-3"></i> USER MANAGEMENT
                    </a>
                    <a href="@Url.Action("SubmissionSettings", "Admin")" class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SubmissionSettings" ? "active" : "")">
                        <i class="bi bi-clock-history me-3"></i> SUBMISSION
                    </a>
                    <a href="@Url.Action("Analysis", "Admin")" class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Analysis" ? "active" : "")">
                        <i class="bi bi-graph-up me-3"></i> ANALYTICS
                    </a>
                </nav>

                <div class="px-4 mt-auto">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-link sidebar-link text-danger border-0 w-100 text-start">
                            <i class="bi bi-power me-3"></i> TERMINATION
                        </button>
                    </form>
                </div>
            </aside>

            <main class="main-content page-ready" id="main-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <header class="glass-card m-3 py-3 px-4 d-flex align-items-center justify-content-between">
            <a class="h5 mb-0 fw-bold gradient-text text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-dot"></span> BLINDMATCH
            </a>
            @if (ViewContext.RouteData.Values["Action"]?.ToString() != "Login")
            {
                <nav>
                    <ul class="nav">
                        @if (!(User.IsInRole("Student") || User.IsInRole("Supervisor")))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark fw-medium">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline" id="logoutForm">
                                    <button type="submit" class="nav-link btn btn-link text-dark fw-medium border-0" id="headerLogoutBtn">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary-gradient px-4" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </header>

        <main class="container py-4 page-ready" id="main-content">
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("PageScripts", required: false)
</body>
</html>
