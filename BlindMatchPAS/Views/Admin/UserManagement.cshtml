@using BlindMatchPAS.Models
@using Microsoft.AspNetCore.Identity
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
    var supervisors = (IList<ApplicationUser>)ViewBag.Supervisors;
    var students = (IList<ApplicationUser>)ViewBag.Students;
    var admins = (IList<ApplicationUser>)ViewBag.Admins;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold gradient-text mb-1">USER MANAGEMENT</h1>
            <p class="text-muted">Identity Registry and Manual Registration Backup</p>
        </div>
        <div class="text-end">
            <a asp-action="RegisterUser" class="btn btn-primary-gradient px-4">
                <i class="bi bi-person-plus me-2"></i> Register New User
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabs -->
    <ul class="nav nav-pills mb-4 gap-2" id="userTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#admins">
                <i class="bi bi-shield-lock me-2"></i> ADMINS (@admins.Count)
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#supervisors">
                <i class="bi bi-person-badge me-2"></i> SUPERVISORS (@supervisors.Count)
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#students">
                <i class="bi bi-mortarboard me-2"></i> STUDENTS (@students.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content glass-card">
        <div class="tab-pane fade show active" id="admins">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-muted small">
                            <th>IDENTITY</th>
                            <th>COMMUNICATION</th>
                            <th>ROLE</th>
                            <th>STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in admins)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar bg-danger-subtle text-danger fw-bold rounded-circle flex-center" style="width: 35px; height: 35px;">
                                            @(user.FullName?.FirstOrDefault().ToString() ?? "A")
                                        </div>
                                        <span class="fw-bold">@user.FullName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td><span class="badge bg-danger-subtle text-danger border border-danger">System Admin</span></td>
                                <td><span class="badge bg-success-subtle text-success border border-success">Active</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-pane fade" id="supervisors">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-muted small">
                            <th>IDENTITY</th>
                            <th>COMMUNICATION</th>
                            <th>STATUS</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in supervisors)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar bg-purple-subtle text-purple fw-bold rounded-circle flex-center" style="width: 35px; height: 35px;">
                                            @(user.FullName?.FirstOrDefault().ToString() ?? "U")
                                        </div>
                                        <span class="fw-bold">@user.FullName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td><span class="badge bg-success-subtle text-success border border-success">Active</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-slash-circle me-1"></i> Suspend</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-pane fade" id="students">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-muted small">
                            <th>IDENTITY</th>
                            <th>COMMUNICATION</th>
                            <th>STATUS</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in students)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar bg-teal-subtle text-teal fw-bold rounded-circle flex-center" style="width: 35px; height: 35px;">
                                            @(user.FullName?.FirstOrDefault().ToString() ?? "U")
                                        </div>
                                        <span class="fw-bold">@user.FullName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td><span class="badge bg-success-subtle text-success border border-success">Active</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-slash-circle me-1"></i> Suspend</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link.active { background: var(--gradient-primary) !important; color: white !important; }
    .nav-pills .nav-link { color: var(--color-text-secondary); background: rgba(255,255,255,0.5); border: 1px solid var(--color-border-primary); }
    .avatar { display: flex; align-items: center; justify-content: center; font-size: 14px; }
</style>
