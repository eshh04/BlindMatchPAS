@using BlindMatchPAS.Models
@using Microsoft.AspNetCore.Identity
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
    var supervisors = (IList<ApplicationUser>)ViewBag.Supervisors;
    var students = (IList<ApplicationUser>)ViewBag.Students;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold gradient-text mb-1">USER MANAGEMENT</h1>
            <p class="text-muted">Identity Registry and Manual Registration Backup</p>
        </div>
        <div class="text-end">
            <button class="btn btn-primary-gradient px-4" data-bs-toggle="modal" data-bs-target="#registerModal">
                <i class="bi bi-person-plus me-2"></i> Register New User
            </button>
        </div>
    </div>

    <!-- Registration Modal -->
    <div class="modal fade" id="registerModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card p-4 border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold mb-0">Register User Manual</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-4">
                    <form asp-action="RegisterUserManual" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">FULL NAME</label>
                            <input type="text" name="fullName" class="form-control rounded-3" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">EMAIL ADDRESS</label>
                            <input type="email" name="email" class="form-control rounded-3" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">ROLE</label>
                            <select name="role" class="form-select rounded-3">
                                <option value="Student">Student</option>
                                <option value="Supervisor">Supervisor</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">INITIAL PASSWORD</label>
                            <input type="password" name="password" class="form-control rounded-3" value="User@2026!" required />
                        </div>
                        <button type="submit" class="btn btn-primary-gradient w-100 py-3">AUTHORIZE ACCESS</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-pills mb-4 gap-2" id="userTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#supervisors">
                <i class="bi bi-person-badge me-2"></i> SUPERVISORS (@supervisors.Count)
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#students">
                <i class="bi bi-mortarboard me-2"></i> STUDENTS (@students.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content glass-card">
        <div class="tab-pane fade show active" id="supervisors">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-muted small">
                            <th>IDENTITY</th>
                            <th>COMMUNICATION</th>
                            <th>STATUS</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in supervisors)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar bg-purple-subtle text-purple fw-bold rounded-circle flex-center" style="width: 35px; height: 35px;">
                                            @(user.FullName?.FirstOrDefault().ToString() ?? "U")
                                        </div>
                                        <span class="fw-bold">@user.FullName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td><span class="badge bg-success-subtle text-success border border-success">Active</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-slash-circle me-1"></i> Suspend</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-pane fade" id="students">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="text-muted small">
                            <th>IDENTITY</th>
                            <th>COMMUNICATION</th>
                            <th>STATUS</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in students)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar bg-teal-subtle text-teal fw-bold rounded-circle flex-center" style="width: 35px; height: 35px;">
                                            @(user.FullName?.FirstOrDefault().ToString() ?? "U")
                                        </div>
                                        <span class="fw-bold">@user.FullName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td><span class="badge bg-success-subtle text-success border border-success">Active</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-slash-circle me-1"></i> Suspend</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link.active { background: var(--gradient-primary) !important; color: white !important; }
    .nav-pills .nav-link { color: var(--color-text-secondary); background: rgba(255,255,255,0.5); border: 1px solid var(--color-border-primary); }
    .avatar { display: flex; align-items: center; justify-content: center; font-size: 14px; }
</style>
