@using BlindMatchPAS.Models
@using Microsoft.AspNetCore.Identity
@model IList<ApplicationUser>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Settings";
}

<div class="page-header mb-5 flex-between">
    <div>
        <h1 class="gradient-text display-4 fw-bold">Admin Management</h1>
        <p class="text-muted fw-medium text-uppercase ls-wide">Access Control // Security Settings</p>
    </div>
    <a href="@Url.Action("Register", "Account")" class="btn btn-purple rounded-pill px-4 shadow-md">+ New Admin Account</a>
</div>

<div class="glass rounded-2xl overflow-hidden shadow-lg mb-5">
    <div class="bg-overlay p-4 border-bottom glass-sm flex-between">
        <h3 class="h5 fw-bold mb-0 gradient-text">System Administrators (@Model.Count)</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-tertiary">
                <tr>
                    <th class="ps-4">Administrator</th>
                    <th>Email</th>
                    <th>System Role</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var admin in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle-sm bg-purple-light me-2">
                                    <i class="bi bi-shield-lock-fill text-purple"></i>
                                </div>
                                <span class="fw-bold">@admin.FullName</span>
                            </div>
                        </td>
                        <td class="text-muted small">@admin.Email</td>
                        <td>
                            <span class="badge glass-sm border-purple text-purple rounded-pill">Full Controller</span>
                        </td>
                        <td class="text-end pe-4">
                            @if (Model.Count > 1)
                            {
                                <form method="post" asp-action="DeleteAdmin" asp-controller="Admin" style="margin:0;">
                                    <input type="hidden" name="id" value="@admin.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Revoke Access</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small italic">Primary (Protected)</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="glass rounded-xl p-4 shadow-sm">
    <h3 class="h6 fw-bold mb-3 text-purple"><i class="bi bi-info-circle me-2"></i>Security Guidelines</h3>
    <ul class="text-muted small mb-0">
        <li>Administrators have full read/write access to all project and user modules.</li>
        <li>Account revocation is immediate and will terminate the user's active session.</li>
        <li>The system requires at least one primary administrator account for emergency recovery.</li>
    </ul>
</div>

<style>
    .ls-wide { letter-spacing: 0.1em; }
    .avatar-circle-sm {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
    }
    .bg-purple-light { background-color: rgba(124, 58, 237, 0.1); }
    .text-purple { color: #7c3aed !important; }
    .btn-purple { 
        background-color: #7c3aed; 
        color: white; 
        border: none;
    }
    .btn-purple:hover { 
        background-color: #6d28d9; 
        color: white; 
    }
    .italic { font-style: italic; }
</style>
