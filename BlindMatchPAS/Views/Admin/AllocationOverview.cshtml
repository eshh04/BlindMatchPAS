@model List<BlindMatchPAS.Models.Project>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Allocation Matrix";
    var supervisors = (IList<BlindMatchPAS.Models.ApplicationUser>)ViewBag.Supervisors;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold gradient-text mb-1">ALLOCATION MATRIX</h1>
            <p class="text-muted">Review and override project-supervisor mapping</p>
        </div>
        <div class="text-end d-flex gap-2">
            <button class="btn btn-outline-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#manualAllocationModal">
                <i class="bi bi-plus-circle me-2"></i> Manual Backup
            </button>
            <span class="badge bg-success-subtle text-success border border-success px-3 py-2">
                <i class="bi bi-shield-check me-2"></i> CORE_STABLE
            </span>
        </div>
    </div>

    <!-- Manual Allocation Modal -->
    <div class="modal fade" id="manualAllocationModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card p-4 border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold mb-0">Manual Allocation Backup</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-4">
                    <form asp-action="AddManualAllocation" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">STUDENT EMAIL</label>
                            <input type="email" name="studentEmail" class="form-control rounded-3" placeholder="identity@system.core" required />
                            <div class="form-text x-small">If student doesn't exist, an account will be created.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">PROJECT TITLE</label>
                            <input type="text" name="projectTitle" class="form-control rounded-3" placeholder="Final Year Project" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">TARGET SUPERVISOR</label>
                            <select name="supervisorId" class="form-select rounded-3" required>
                                <option value="">Select Supervisor...</option>
                                @foreach (var s in supervisors)
                                {
                                    <option value="@s.Id">@s.FullName</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary-gradient w-100 py-3">FORCED ALLOCATION</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-card p-4 mb-4">
        <div class="row g-3">
            @foreach (var project in Model)
            {
                var currentMatch = project.Matches?.FirstOrDefault(m => m.Status == BlindMatchPAS.Enums.MatchStatus.Confirmed);
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-3" style="background: rgba(255,255,255,0.5);">
                        <div class="row align-items-center">
                            <div class="col-md-5">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <span class="badge bg-purple-subtle text-purple border border-purple">PRJ-@project.Id.ToString("D4")</span>
                                    <h5 class="mb-0 fw-bold">@project.Title</h5>
                                </div>
                                <div class="d-flex gap-3 text-muted small">
                                    <span><i class="bi bi-person me-1"></i> @(project.IsRevealed ? project.Student?.FullName : "IDENTITY_ENCRYPTED")</span>
                                    <span><i class="bi bi-tag me-1"></i> @project.ResearchArea?.Name</span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <form asp-action="UpdateAllocation" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="projectId" value="@project.Id" />
                                    <select name="supervisorId" class="form-select border-0 shadow-sm rounded-3">
                                        <option value="">Select Supervisor...</option>
                                        @foreach (var s in supervisors)
                                        {
                                            var isSelected = currentMatch?.SupervisorId == s.Id;
                                            <!option value="@s.Id" @(isSelected ? "selected" : "")>@s.FullName</!option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-primary-gradient">Assign</button>
                                </form>
                            </div>

                            <div class="col-md-3 text-end">
                                <form asp-action="ToggleReveal" method="post" class="d-inline">
                                    <input type="hidden" name="projectId" value="@project.Id" />
                                    <button type="submit" class="btn @(project.IsRevealed ? "btn-success" : "btn-outline-secondary") rounded-pill px-4">
                                        <i class="bi @(project.IsRevealed ? "bi-eye" : "bi-eye-slash") me-2"></i>
                                        @(project.IsRevealed ? "Revealed" : "Reveal")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-purple-subtle { background-color: #f3e8ff !important; }
    .text-purple { color: #7c3aed !important; }
    .border-purple { border-color: #ddd6f3 !important; }
    .card:hover { transform: scale(1.01); transition: transform 0.2s; }
</style>
