@model List<BlindMatchPAS.Models.ResearchArea>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Research Vectors";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold gradient-text mb-1">RESEARCH VECTORS</h1>
            <p class="text-muted">Domain Registry and Classification Nodes</p>
        </div>
        <div class="text-end">
            <span class="badge bg-success-subtle text-success border border-success px-3 py-2">
                <i class="bi bi-diagram-3 me-2"></i> DOMAIN_ACTIVE
            </span>
        </div>
    </div>

    <!-- Registration Panel -->
    <div class="glass-card mb-5">
        <h5 class="fw-bold mb-4">Register New Research Node</h5>
        <form asp-action="Create" method="post" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="name" class="form-control rounded-3 py-2" placeholder="Area Name" required />
            </div>
            <div class="col-md-6">
                <input type="text" name="description" class="form-control rounded-3 py-2" placeholder="Technical Description" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary-gradient w-100 py-2">REGISTER</button>
            </div>
        </form>
    </div>

    <div class="glass-card p-0 overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-muted small">
                        <th class="ps-4">ID</th>
                        <th>AREA NAME</th>
                        <th>TECHNICAL DESCRIPTION</th>
                        <th class="text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var area in Model)
                    {
                        <tr>
                            <td class="ps-4"><span class="badge bg-light text-dark border font-monospace">#@area.Id.ToString("D4")</span></td>
                            <td><span class="fw-bold">@area.Name</span></td>
                            <td class="text-muted small">@(string.IsNullOrEmpty(area.Description) ? "NO_DESCRIPTION_PROVIDED" : area.Description)</td>
                            <td class="text-end pe-4">
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this node?');" class="d-inline">
                                    <input type="hidden" name="id" value="@area.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
