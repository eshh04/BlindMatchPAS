@model BlindMatchPAS.Models.ResearchArea
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Research Area";
    ViewData["ActivePage"] = "ResearchArea";
}

<div class="page-header">
    <h1 class="page-title">Edit Research Area</h1>
    <p class="page-subtitle">UPDATE // ID:@Model.Id</p>
</div>

<div class="form-card">
    <form method="post" asp-action="Edit" asp-controller="ResearchArea">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="form-group">
            <label for="name">Area Name</label>
            <input type="text" id="name" name="name" value="@Model.Name" required />
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description">@Model.Description</textarea>
        </div>

        <div class="btn-group">
            <button type="submit" class="nothing-button">Save Changes</button>
            <a href="@Url.Action("Index", "ResearchArea")" class="nothing-button btn-outline">Cancel</a>
        </div>
    </form>
</div>
