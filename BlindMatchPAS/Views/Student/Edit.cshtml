@model EditProjectViewModel
@{
    ViewData["Title"] = "Edit Project";
}

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <h1>Edit Your Project</h1>
        <p class="text-muted mb-4">Update your project details</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <strong>Please fix the errors below:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <form method="post" asp-action="Edit" class="needs-validation">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Project Details</h5>
                </div>
                <div class="card-body">
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="form-label">Project Title</label>
                        <input asp-for="Title" type="text" class="form-control" />
                        <small class="text-muted">10-200 characters</small>
                        <span asp-validation-for="Title" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Abstract" class="form-label">Project Abstract</label>
                        <textarea asp-for="Abstract" class="form-control" rows="5" data-counter="abstractCounter" data-maxlength="2000"></textarea>
                        <small id="abstractCounter" class="text-muted d-block mt-2">0 / 2000 characters</small>
                        <span asp-validation-for="Abstract" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="TechStack" class="form-label">Technology Stack <span class="text-danger">*</span></label>
                        <input asp-for="TechStack" type="text" class="form-control" />
                        <small class="text-muted">Up to 500 characters</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="ResearchAreaId" class="form-label">Research Area</label>
                        <select asp-for="ResearchAreaId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.ResearchAreas">
                            <option value="">-- Select Research Area --</option>
                        </select>
                        <span asp-validation-for="ResearchAreaId" class="invalid-feedback d-block"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
