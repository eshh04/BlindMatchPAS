@model CreateProjectViewModel
@{
    ViewData["Title"] = "Submit Project";
}

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <h1>Submit Your Project</h1>
        <p class="text-muted mb-4">Tell us about your project and select a research area that best matches your work.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <strong>Please fix the errors below:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <form method="post" asp-action="Create" class="needs-validation">
            @Html.AntiForgeryToken()

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Project Details</h5>
                </div>
                <div class="card-body">
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="form-label">Project Title</label>
                        <input asp-for="Title" type="text" class="form-control" placeholder="e.g., AI-Powered Recommendation Engine" />
                        <small class="text-muted">10-200 characters</small>
                        <span asp-validation-for="Title" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Abstract" class="form-label">Project Abstract</label>
                        <textarea asp-for="Abstract" class="form-control" rows="5" placeholder="Describe your project, its goals, and technical approach..." data-counter="abstractCounter" data-maxlength="2000"></textarea>
                        <small id="abstractCounter" class="text-muted d-block mt-2">0 / 2000 characters</small>
                        <span asp-validation-for="Abstract" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="TechStack" class="form-label">Technology Stack <span class="text-danger">*</span></label>
                        <input asp-for="TechStack" type="text" class="form-control" placeholder="e.g., Python, TensorFlow, PostgreSQL, React" />
                        <small class="text-muted">Up to 500 characters</small>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="ResearchAreaId" class="form-label">Research Area</label>
                        <select asp-for="ResearchAreaId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.ResearchAreas">
                            <option value="">-- Select Research Area --</option>
                        </select>
                        <span asp-validation-for="ResearchAreaId" class="invalid-feedback d-block"></span>
                    </div>

                    @{
                        var allowedTypes = ViewBag.SubmissionConfig?.AllowedProjectTypes ?? "Individual";
                        bool forceIndividual = allowedTypes == "Individual";
                        bool forceGroup = allowedTypes == "Group";
                        bool showToggle = allowedTypes == "Both";
                    }

                    @if (!forceIndividual)
                    {
                        <hr />
                        
                        @if (showToggle)
                        {
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" role="switch" asp-for="IsGroupProject" id="isGroupProjectToggle">
                                <label class="form-check-label fw-bold" asp-for="IsGroupProject">This is a Group Project</label>
                            </div>
                        }
                        else if (forceGroup)
                        {
                            <!-- Force the value to true, hide the toggle -->
                            <input type="hidden" name="IsGroupProject" value="true" id="isGroupProjectToggle" checked />
                            <div class="alert alert-info py-2 small mb-3">
                                <i class="bi bi-info-circle me-1"></i> Only group projects are allowed in this submission window.
                            </div>
                        }

                        <div class="form-group" id="groupMembersSection" style="@(forceGroup ? "display: block;" : "display: none;")">
                            <label asp-for="GroupMemberEmails" class="form-label">Co-Collaborator Emails <span class="text-danger">*</span></label>
                            <input asp-for="GroupMemberEmails" type="text" class="form-control" placeholder="student2@blindmatch.com, student3@blindmatch.com" />
                            <small class="text-muted">Enter valid email addresses separated by commas.</small>
                            <span asp-validation-for="GroupMemberEmails" class="invalid-feedback d-block"></span>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Submit Project</button>
                <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section PageScripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggle = document.getElementById('isGroupProjectToggle');
            const section = document.getElementById('groupMembersSection');
            
            function updateVisibility() {
                if (toggle.checked) {
                    section.style.display = 'block';
                    section.classList.add('fade-in');
                } else {
                    section.style.display = 'none';
                }
            }
            
            toggle.addEventListener('change', updateVisibility);
            updateVisibility(); // Initial load
        });
    </script>
}
