@{
    Layout = "_Layout";
    ViewData["Title"] = "Reset Password";
    var email = ViewBag.Email as string ?? "";
    var fullName = ViewBag.FullName as string ?? "User";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="glass-card p-5 shadow-2xl" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-5">
            <div class="d-flex align-items-center justify-content-center mb-3">
                <span class="brand-dot"></span>
                <span class="h4 mb-0 fw-bold gradient-text">BLINDMATCH PAS</span>
            </div>
            <div class="mb-3">
                <span style="font-size: 3rem;">🔒</span>
            </div>
            <h2 class="fw-bold text-dark">Reset Password</h2>
            <p class="text-muted small">
                Setting new password for<br />
                <strong class="gradient-text">@fullName</strong>
            </p>
            <div class="badge bg-light text-muted border small py-2 px-3 rounded-pill">
                <i class="bi bi-envelope me-1"></i>@email
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small mb-4 border-0 rounded-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="bi bi-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@email" />

            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">NEW PASSWORD</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                    <input type="password" name="newPassword" id="newPassword"
                           class="form-control border-start-0 py-3 ps-0"
                           placeholder="Min 8 chars, uppercase, number, symbol" required />
                </div>
                <small class="text-muted">Must include uppercase, number, and a special character.</small>
            </div>

            <div class="mb-5">
                <label class="form-label text-muted small fw-bold">CONFIRM NEW PASSWORD</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-shield-check text-muted"></i></span>
                    <input type="password" name="confirmPassword" id="confirmPassword"
                           class="form-control border-start-0 py-3 ps-0"
                           placeholder="••••••••" required />
                </div>
                <small id="matchMessage" class="d-none"></small>
            </div>

            <button type="submit" class="btn btn-primary-gradient w-100 py-3 fs-6" id="resetBtn">
                RESET PASSWORD <i class="bi bi-check2-circle ms-2"></i>
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-action="Login" class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Back to Login
            </a>
        </div>
    </div>
</div>

<style>
    .input-group-text { border: 1px solid var(--color-border-primary); border-radius: 0.5rem 0 0 0.5rem; }
    .form-control { border: 1px solid var(--color-border-primary); border-radius: 0 0.5rem 0.5rem 0; }
    .form-control:focus { box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1); border-color: var(--color-purple); }
</style>

@section PageScripts {
<script>
    const newPwd = document.getElementById('newPassword');
    const confirmPwd = document.getElementById('confirmPassword');
    const matchMsg = document.getElementById('matchMessage');

    function checkMatch() {
        if (confirmPwd.value.length === 0) { matchMsg.className = 'd-none'; return; }
        if (newPwd.value === confirmPwd.value) {
            matchMsg.textContent = '✓ Passwords match';
            matchMsg.className = 'text-success small';
        } else {
            matchMsg.textContent = '✗ Passwords do not match';
            matchMsg.className = 'text-danger small';
        }
    }
    newPwd.addEventListener('input', checkMatch);
    confirmPwd.addEventListener('input', checkMatch);
</script>
}
