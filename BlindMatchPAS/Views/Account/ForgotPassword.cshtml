@{
    Layout = "_Layout";
    ViewData["Title"] = "Forgot Password";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="glass-card p-5 shadow-2xl" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-5">
            <div class="d-flex align-items-center justify-content-center mb-3">
                <span class="brand-dot"></span>
                <span class="h4 mb-0 fw-bold gradient-text">BLINDMATCH PAS</span>
            </div>
            <div class="mb-3">
                <span style="font-size: 3rem;">🔑</span>
            </div>
            <h2 class="fw-bold text-dark">Forgot Password?</h2>
            <p class="text-muted small">Enter your registered email address to reset your password.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small mb-4 border-0 rounded-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="bi bi-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">EMAIL ADDRESS</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                    <input type="email" name="email" class="form-control border-start-0 py-3 ps-0"
                           placeholder="user@example.com" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary-gradient w-100 py-3 fs-6">
                FIND MY ACCOUNT <i class="bi bi-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-action="Login" class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Back to Login
            </a>
        </div>
    </div>
</div>

<style>
    .input-group-text { border: 1px solid var(--color-border-primary); border-radius: 0.5rem 0 0 0.5rem; }
    .form-control { border: 1px solid var(--color-border-primary); border-radius: 0 0.5rem 0.5rem 0; }
    .form-control:focus { box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1); border-color: var(--color-purple); }
</style>
