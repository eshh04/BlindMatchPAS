@using BlindMatchPAS.ViewModels
@model LoginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Authentication";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="glass-card p-5 shadow-2xl" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-5">
            <div class="d-flex align-items-center justify-content-center mb-3">
                <span class="brand-dot"></span>
                <span class="h4 mb-0 fw-bold gradient-text">BLINDMATCH PAS</span>
            </div>
            <h2 class="fw-bold text-dark">Welcome Back</h2>
            <p class="text-muted small">Please enter your credentials to continue</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4 border-0 rounded-3"></div>

        <form asp-action="Login" method="post" class="needs-validation">
            <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">EMAIL ADDRESS</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                    <input asp-for="Email" class="form-control border-start-0 py-3 ps-0" placeholder="user@example.com" required />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">PASSWORD</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 py-3 ps-0" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-2 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label class="form-check-label text-muted small" asp-for="RememberMe">Remember me for 30 days</label>
            </div>

            <div class="text-end mb-4">
                <a asp-action="ForgotPassword" class="text-muted small text-decoration-none" style="color: var(--color-purple) !important;">
                    <i class="bi bi-key me-1"></i>Forgot Password?
                </a>
            </div>

            <button type="submit" class="btn btn-primary-gradient w-100 py-3 fs-6">
                SIGN IN <i class="bi bi-arrow-right ms-2"></i>
            </button>

            <div class="text-center mt-4">
                <p class="text-muted small">Don't have an account?</p>
                <a asp-action="Register" target="_blank" class="btn btn-outline-secondary w-100 py-2 fs-6 rounded-3">
                    CREATE STUDENT ACCOUNT
                </a>
            </div>
        </form>

        <div class="text-center mt-5">
            <div class="d-flex align-items-center justify-content-center gap-3">
                <span class="text-[10px] text-muted uppercase tracking-widest"><i class="bi bi-circle-fill text-success small me-2"></i>System Online</span>
                <span class="text-[10px] text-muted uppercase tracking-widest fw-bold">SECURED_NODE_@DateTime.Now.Year</span>
            </div>
        </div>
    </div>
</div>

<style>
    .input-group-text { border: 1px solid var(--color-border-primary); border-radius: 0.5rem 0 0 0.5rem; }
    .form-control { border: 1px solid var(--color-border-primary); border-radius: 0 0.5rem 0.5rem 0; }
    .form-control:focus { box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1); border-color: var(--color-purple); }
    .form-check-input:checked { background-color: var(--color-purple); border-color: var(--color-purple); }
</style>
