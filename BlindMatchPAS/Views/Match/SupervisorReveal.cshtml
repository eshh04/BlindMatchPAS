@model RevealedMatchDto
@{
    ViewData["Title"] = "Student Details - Your Match";
}

<div class="row">
    <div class="col-lg-6 offset-lg-3">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">👁️ Matched Student Details</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-success mb-4">
                    Here are the details of the student matched with your project:
                </div>

                <div class="mb-4">
                    <h5 class="text-muted small">Student Name</h5>
                    <h4 class="mb-0">@Model.PersonFullName</h4>
                </div>

                <div class="mb-4">
                    <h5 class="text-muted small">Email</h5>
                    <p class="mb-0">
                        <a href="mailto:@Model.PersonEmail">@Model.PersonEmail</a>
                    </p>
                </div>

                <div class="mb-4">
                    <h5 class="text-muted small">Project</h5>
                    <p class="mb-0">@Model.ExtraInfo</p>
                </div>

                <div class="mb-4">
                    <h5 class="text-muted small">Match Confirmed</h5>
                    <p class="mb-0">@Model.MatchedAt.ToString("MMMM d, yyyy")</p>
                </div>

                @if (Model.IsGroupProject)
                {
                    <div class="mb-4">
                        <h5 class="text-muted small">Project Type</h5>
                        <span class="badge bg-purple">Group Project</span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.GroupMemberEmails))
                    {
                        <div class="mb-4">
                            <h5 class="text-muted small">Co-Collaborators</h5>
                            <p class="mb-0 text-muted">
                                @Model.GroupMemberEmails
                            </p>
                        </div>
                    }
                }
                else
                {
                    <div class="mb-4">
                        <h5 class="text-muted small">Project Type</h5>
                        <span class="badge bg-secondary">Individual Project</span>
                    </div>
                }
            </div>
            <div class="card-footer">
                <a href="javascript:history.back()" class="btn btn-primary">Go Back</a>
            </div>
        </div>
    </div>
</div>
