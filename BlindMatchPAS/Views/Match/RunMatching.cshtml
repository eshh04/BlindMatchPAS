@{
    ViewData["Title"] = "Run Stable Matching";
}

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <h1>Run Stable Matching Algorithm</h1>
        <p class="text-muted mb-4">Execute the Gale-Shapley deferred acceptance algorithm to match projects with supervisors.</p>

        @if (ViewBag.MatchedCount > 0)
        {
            <div class="alert alert-success">
                <h5 class="alert-heading">✓ Matching Completed Successfully</h5>
                <p>@ViewBag.MatchedCount project(s) have been matched with supervisors.</p>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Matched Projects</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Project ID</th>
                                    <th>Supervisor ID</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.NewMatches != null)
                                {
                                    foreach (dynamic match in ViewBag.NewMatches)
                                    {
                                        <tr>
                                            <td>@match</td>
                                            <td>-</td>
                                            <td>
                                                <small class="text-success">✓ Matched</small>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                No new matches were created. All projects may already be matched, or there may be no students/supervisors with matching interests.
            </div>
        }

        <div class="mt-4">
            <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
        </div>
    </div>
</div>
