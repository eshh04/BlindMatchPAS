@model BlindMatchPAS.Models.ProjectProposal

@{
    ViewData["Title"] = "Proposal Details";
}

<h1>Details</h1>

<div>
    <h4>Project Proposal Information</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Abstract)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Abstract)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TechnicalStack)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TechnicalStack)
        </dd>

        @* Displaying only the Research Area Name for a cleaner UI *@
        <dt class="col-sm-2">
            Research Area
        </dt>
        <dd class="col-sm-10">
            @Model.ResearchArea?.Name
        </dd>

        @* Note: 'IsMatched' and 'Status' are hidden from the student's view for security and clarity *@
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ProjectID" class="btn btn-warning">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>